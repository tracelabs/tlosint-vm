#!/usr/bin/env python3
# ============================================================
# Trace Labs VM Updater - GTK3 GUI
# Shows live update output in a terminal-style window
# ============================================================

import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib, Gdk
import subprocess
import threading
import os
import sys

UPDATE_SCRIPT = "/usr/local/bin/tl-run-updates"

CSS = b"""
window {
    background-color: #0f0f1a;
}
.terminal-view {
    background-color: #1a1a2e;
    color: #00ff88;
    font-family: monospace;
    font-size: 13px;
    padding: 10px;
}
.terminal-view text {
    background-color: #1a1a2e;
    color: #00ff88;
}
.status-bar {
    background-color: #16213e;
    color: #a0a0b0;
    padding: 8px 16px;
    font-size: 12px;
}
.btn-start {
    background: #00b4d8;
    background-image: none;
    color: #000000;
    font-weight: bold;
    border-radius: 4px;
    padding: 6px 16px;
    border: none;
}
.btn-start:hover {
    background: #00d4ff;
    background-image: none;
    color: #000000;
}
.btn-start:disabled {
    background: #444466;
    background-image: none;
    color: #888888;
}
progressbar trough {
    background-color: #16213e;
}
progressbar progress {
    background-color: #00b4d8;
}
"""

class TraceLaboratoriesUpdater(Gtk.Window):
    def __init__(self):
        super().__init__(title="Trace Labs VM Updater")
        self.set_default_size(780, 540)
        self.set_resizable(True)
        self.set_border_width(0)

        # Apply CSS
        css_provider = Gtk.CssProvider()
        css_provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(),
            css_provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION
        )

        # Header bar
        header = Gtk.HeaderBar()
        header.set_title("Trace Labs VM Updater")
        header.set_subtitle("Keeping your OSINT tools sharp")
        header.set_show_close_button(True)
        self.set_titlebar(header)

        # Main layout
        vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.add(vbox)

        # Status label
        self.status_label = Gtk.Label(label="Ready — click Start Update to begin.")
        self.status_label.get_style_context().add_class("status-bar")
        self.status_label.set_xalign(0)
        self.status_label.set_margin_top(0)
        vbox.pack_start(self.status_label, False, False, 0)

        # Terminal output area
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        scroll.set_margin_start(12)
        scroll.set_margin_end(12)
        scroll.set_margin_top(10)
        scroll.set_margin_bottom(6)

        self.textview = Gtk.TextView()
        self.textview.set_editable(False)
        self.textview.set_cursor_visible(False)
        self.textview.set_monospace(True)
        self.textview.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        self.textview.get_style_context().add_class("terminal-view")
        self.textbuffer = self.textview.get_buffer()

        scroll.add(self.textview)
        vbox.pack_start(scroll, True, True, 0)

        # Progress bar
        self.progress = Gtk.ProgressBar()
        self.progress.set_margin_start(12)
        self.progress.set_margin_end(12)
        self.progress.set_margin_top(4)
        self.progress.set_margin_bottom(4)
        vbox.pack_start(self.progress, False, False, 0)

        # Button row
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_margin_start(12)
        btn_box.set_margin_end(12)
        btn_box.set_margin_bottom(12)
        btn_box.set_margin_top(4)

        self.update_btn = Gtk.Button(label="[ Start Update ]")
        self.update_btn.get_style_context().add_class("btn-start")
        self.update_btn.connect("clicked", self.start_update)

        self.close_btn = Gtk.Button(label="Close")
        self.close_btn.connect("clicked", lambda w: self.destroy())

        btn_box.pack_start(self.update_btn, False, False, 0)
        btn_box.pack_end(self.close_btn, False, False, 0)
        vbox.pack_start(btn_box, False, False, 0)

        self.process = None
        self.update_running = False

        self.append_text("=== Trace Labs VM Updater ===\n")
        self.append_text("System and OSINT tool updater ready.\n")
        self.append_text("Click 'Start Update' to begin.\n\n")

    def append_text(self, text):
        def _append():
            end_iter = self.textbuffer.get_end_iter()
            self.textbuffer.insert(end_iter, text)
            mark = self.textbuffer.get_insert()
            self.textview.scroll_mark_onscreen(mark)
        GLib.idle_add(_append)

    def start_update(self, widget):
        if self.update_running:
            return
        self.update_running = True
        self.update_btn.set_sensitive(False)
        self.update_btn.set_label("[ Updating... ]")
        self.status_label.set_text("Update in progress — please don't close this window...")
        thread = threading.Thread(target=self.run_update, daemon=True)
        thread.start()
        GLib.timeout_add(300, self.pulse_progress)

    def pulse_progress(self):
        if self.update_running:
            self.progress.pulse()
            return True
        return False

    def run_update(self):
        try:
            self.process = subprocess.Popen(
                ["pkexec", UPDATE_SCRIPT],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                bufsize=1
            )
            for line in iter(self.process.stdout.readline, ''):
                self.append_text(line)
            self.process.wait()
            GLib.idle_add(self.update_complete, self.process.returncode)
        except Exception as e:
            self.append_text(f"\n[ERROR] {e}\n")
            GLib.idle_add(self.update_complete, 1)

    def update_complete(self, returncode):
        self.update_running = False
        self.progress.set_fraction(1.0)
        if returncode == 0:
            self.status_label.set_text("✅  Update complete! Your tools are up to date.")
            self.append_text("\n=== All updates complete. ===\n")
            try:
                os.remove("/var/cache/tracelabs/update-available")
            except FileNotFoundError:
                pass
        else:
            self.status_label.set_text("⚠️  Update finished with errors — check output above.")
            self.append_text(f"\n=== Finished with return code {returncode} ===\n")
        self.update_btn.set_label("[ Run Again ]")
        self.update_btn.set_sensitive(True)

def main():
    win = TraceLaboratoriesUpdater()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()

if __name__ == "__main__":
    main()
